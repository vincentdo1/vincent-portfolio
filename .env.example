# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# Required for the /api/contact route to actually send emails.

# ── Resend (https://resend.com) ────────────────────────────────────────────
# 1. Sign up at https://resend.com (free tier: 100 emails/day, 3000/month).
# 2. Create an API key in the dashboard.
# 3. Paste it below.
RESEND_API_KEY=

# Optional. Defaults to "Portfolio <onboarding@resend.dev>" (Resend's test
# domain). To send from your own domain, verify vmd306.com in the Resend
# dashboard (add their SPF/DKIM/DMARC DNS records) and set this.
# RESEND_FROM_EMAIL="Portfolio <noreply@vmd306.com>"

# Optional. Defaults to vincentdo306@gmail.com.
# RESEND_TO_EMAIL=vincentdo306@gmail.com

# ── Vercel deployment ──────────────────────────────────────────────────────
# Add the same values in your Vercel project:
#   Project → Settings → Environment Variables
